{
  "linux-cachyos": {
    "check_src": true,
    "properties": {
      "_cpusched": "bore",
      "_use_llvm_lto": "full",
      "_processor_opt": "native",
      "_use_lto_suffix": "no",
      "_per_gov": "yes",
      "_tcp_bbr3": "yes",
      "_build_nvidia_open": "yes"
    }
  },
  "linux-cachyos-rc": {
    "check_src": true,
    "properties": {
      "_cpusched": "bore",
      "_use_llvm_lto": "full",
      "_processor_opt": "native",
      "_use_lto_suffix": "no",
      "_per_gov": "yes",
      "_tcp_bbr3": "yes",
      "_build_nvidia_open": "yes"
    }
  },
  "linux-cachyos-deckify": {
    "check_src": false,
    "properties": {
      "_cpusched": "bore",
      "_use_llvm_lto": "full",
      "_processor_opt": "native",
      "_use_lto_suffix": "no",
      "_tcp_bbr3": "yes",
